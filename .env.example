# Copy this file to .env and fill in real values. Never commit .env.

# ── Database ────────────────────────────────────────────────────────────
#
# Local Docker Postgres (docker-compose.yml): DATABASE_URL and DIRECT_URL
# are identical — there is no pooler to route around.
DATABASE_URL="postgresql://postgres:password@localhost:5432/marginflow?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/marginflow?schema=public"
#
# Supabase: DATABASE_URL is the pooled connection (Supavisor/PgBouncer,
# transaction mode, port 6543) — used by the running app (server/db.ts) and
# by `prisma generate`/`validate`. `pgbouncer=true` disables prepared-
# statement-reliant behavior the pooler's transaction mode can't support.
# DIRECT_URL is the direct connection (port 5432) — used only by
# `prisma migrate`/`db push`/`introspect`, which need session-level
# features (advisory locks, long-lived transactions) PgBouncer's
# transaction mode doesn't provide. Get both from
# Project Settings → Database → Connection string in the Supabase dashboard.
#
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# RS256 key pair used to sign/verify access tokens (see server/lib/auth/jwt.ts).
# Generate a local dev pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste each PEM's contents on one line with \n in place of real newlines.
# For local development, you can use the dummy keys below:
