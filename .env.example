# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL 17 connection string used by Prisma (see prisma.config.ts).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marginflow?schema=public"

# RS256 key pair used to sign/verify access tokens (see server/lib/auth/jwt.ts).
# Generate a local dev pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste each PEM's contents on one line with \n in place of real newlines.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
