# pnpm 11 runs an implicit `pnpm install` before `pnpm run`/`pnpm exec`
# (verify-deps-before-run). In this repo that check exits non-zero purely
# because some optional native build scripts are not approved, which blocks
# lint/typecheck/build from ever running. Those build scripts are not needed
# (the Prisma client is already generated; sharp/msw/unrs-resolver are optional),
# so we skip the pre-run verification instead of granting build-script access.
verify-deps-before-run=false
